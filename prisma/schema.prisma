// Luther data model — percentage-savings-projects (spec 2026-07-21)
// All monetary amounts are integer minor units (cents/centavos/céntimos).
// Every financial row carries userId so multi-user is not precluded (single owner in MVP).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  settings             Settings?
  incomeEntries        IncomeEntry[]
  categories           Category[]
  planCells            PlanCell[]
  expenses             Expense[]
  projects             Project[]
  projectContributions ProjectContribution[]
  savingsContributions SavingsContribution[]
}

model Settings {
  userId                  String  @id
  // Manually maintained rate: 1 USD = usdToCrcRate CRC. Stored as decimal string; null = not set.
  usdToCrcRate            String?
  reportingCurrency       String  @default("CRC") // CRC | USD
  startingBalanceMinor    Int     @default(0)
  startingBalanceCurrency String  @default("CRC")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IncomeEntry {
  id          String  @id @default(cuid())
  userId      String
  year        Int
  month       Int // 1-12
  period      String // H1 | H2
  amountMinor Int
  currency    String // CRC | USD
  label       String?
  planned     Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, year, month])
}

model Category {
  id       String  @id @default(cuid())
  userId   String
  name     String
  archived Boolean @default(false)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  planCells PlanCell[]
  expenses  Expense[]

  @@unique([userId, name])
}

model PlanCell {
  id          String @id @default(cuid())
  userId      String
  categoryId  String
  year        Int
  month       Int // 1-12
  amountMinor Int
  currency    String @default("CRC")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, year, month])
  @@index([userId, year])
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  amountMinor Int
  currency    String // CRC | USD — original currency, immutable
  categoryId  String
  name        String?
  /// Paid/done — only completed expenses count toward spent totals (default true preserves history)
  completed   Boolean  @default(true)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId, date])
}

model Project {
  id                String    @id @default(cuid())
  userId            String
  name              String
  costMinor         Int
  currency          String // CRC | USD
  priority          Int
  /// 1–70: percent of post-lifetime leftover (R3)
  allocationPercent Int       @default(50)
  /// H1 | H2 | BOTH
  periodMode        String    @default("BOTH")
  goalDate          DateTime?
  /// Optional product/page URL for the purchase goal
  link              String?
  isPriority        Boolean   @default(false)
  completedAt       DateTime?

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions ProjectContribution[]

  @@index([userId, priority])
  @@index([userId, isPriority])
}

model ProjectContribution {
  id          String @id @default(cuid())
  userId      String
  projectId   String
  year        Int
  month       Int // 1-12
  period      String // H1 | H2
  amountMinor Int
  currency    String
  /// waterfall = auto from income/expenses; manual = legacy/adjustment
  source      String @default("waterfall")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId, year, month, period, source])
  @@index([userId, projectId])
}

model SavingsContribution {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  amountMinor Int // negative = withdrawal; lifetime balance never allowed below zero
  currency    String // CRC | USD
  note        String?
  /// waterfall = auto 70% take; adjustment = manual R9
  source      String   @default("adjustment")
  year        Int?
  month       Int?
  period      String? // H1 | H2 when source=waterfall

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@unique([userId, year, month, period, source])
}
