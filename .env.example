# Luther environment variables — copy to .env and fill in values. Never commit .env.

# Postgres (Supabase). Use the URIs from Project Settings → Database.
# DATABASE_URL = pooled (transaction) URI for the running app
# DIRECT_URL   = direct URI for prisma migrate
DATABASE_URL=""
DIRECT_URL=""

# Auth.js session encryption secret. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Owner account bootstrap (used by `npm run db:seed` only; password is stored hashed)
OWNER_EMAIL=""
OWNER_PASSWORD=""

# Supabase project (optional for Prisma-only access; required if using Supabase client later)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Server-only — never expose to the browser or commit
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_DB_PASSWORD=""
SUPABASE_PROJECT_REF=""
