# Luther environment variables — copy to .env and fill in values. Never commit .env.
# SQLite database location (relative to prisma/ for file: URLs)
DATABASE_URL="file:./dev.db"

# Auth.js session encryption secret. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Owner account bootstrap (used by `npm run db:seed` only; password is stored hashed)
OWNER_EMAIL=""
OWNER_PASSWORD=""
